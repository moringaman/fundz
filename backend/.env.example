# Phemex AI Trader Environment Configuration

# Application
APP_NAME=phemex-ai-trader
APP_VERSION=1.0.0
DEBUG=true
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/phemex_ai_trader

# Redis (for WebSocket pub/sub and caching)
REDIS_URL=redis://redis:6379/0

# Phemex API (get from https://phemex.com/)
PHEMEX_API_KEY=your_api_key_here
PHEMEX_API_SECRET=your_api_secret_here
PHEMEX_TESTNET=true  # Set to false for production

# JWT Secret (generate a random string for production)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate Limiting
RATE_LIMIT_PER_MINUTE=120
